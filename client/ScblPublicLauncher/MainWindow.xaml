<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="SplinterCellCNLauncher.MainWindow"
        Title="SplinterCellCNLauncher Public"
        Icon="/logo.ico"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        FontFamily="Microsoft YaHei UI"
        Height="510"
        Width="420"
        MinHeight="660"
        MinWidth="410"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Background="#071018">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#071018"/>
        <SolidColorBrush x:Key="CardBrush" Color="#111C28"/>
        <SolidColorBrush x:Key="CardLightBrush" Color="#162333"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#26384D"/>
        <SolidColorBrush x:Key="InputBrush" Color="#0A131D"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#30445D"/>
        <SolidColorBrush x:Key="InputFocusBrush" Color="#35D978"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#F5FAFF"/>
        <SolidColorBrush x:Key="TextSubBrush" Color="#9AAABC"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#66778B"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#38DC7B"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#59E991"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#173A28"/>
        <SolidColorBrush x:Key="DangerSoftBrush" Color="#3B1C20"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#E54858"/>
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#F05C6A"/>
        <SolidColorBrush x:Key="BlueSoftBrush" Color="#13253B"/>

        <DropShadowEffect x:Key="CardShadow"
                          Color="#000000"
                          BlurRadius="24"
                          ShadowDepth="8"
                          Opacity="0.28"/>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
        </Style>

        <Style x:Key="CaptionText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextSubBrush}"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextSubBrush}"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2,0,0,7"/>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource InputFocusBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="#0B1722"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.52"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type PasswordBox}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type PasswordBox}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource InputFocusBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="#0B1722"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.52"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CenterTextBox" TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style x:Key="CenterPasswordBox" TargetType="{x:Type PasswordBox}" BasedOn="{StaticResource {x:Type PasswordBox}}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style x:Key="SmallButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="31"/>
            <Setter Property="Foreground" Value="#E4F0FF"/>
            <Setter Property="Background" Value="#203047"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="13,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A3E5A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#182438"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="47"/>
            <Setter Property="Foreground" Value="#021108"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <Grid>
                                <Border CornerRadius="14"
                                        Background="#22FFFFFF"
                                        Height="1"
                                        VerticalAlignment="Top"
                                        Margin="10,1,10,0"/>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2DC869"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="DangerButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="47"/>
            <Setter Property="Foreground" Value="#FFF5F6"/>
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <Grid>
                                <Border CornerRadius="14"
                                        Background="#22FFFFFF"
                                        Height="1"
                                        VerticalAlignment="Top"
                                        Margin="10,1,10,0"/>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DangerHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C73C4B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogPrimaryButton" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Foreground" Value="#021108"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2DC869"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogSecondaryButton" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Foreground" Value="#E4F0FF"/>
            <Setter Property="Background" Value="#203047"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A3E5A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#182438"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="WindowChromeButton" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Foreground" Value="#D7E6F7"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#243850"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#19283A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <Style x:Key="TitleBarTextButton" TargetType="{x:Type Button}" BasedOn="{StaticResource WindowChromeButton}">
            <Setter Property="Width" Value="76"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style x:Key="WindowChromeCloseButton" TargetType="{x:Type Button}" BasedOn="{StaticResource WindowChromeButton}">
            <Setter Property="Foreground" Value="#FFDDE1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DangerBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C73C4B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeListBox" TargetType="{x:Type ListBox}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#0A131D"/>
            <Setter Property="BorderBrush" Value="#2E435D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="3"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type ListBoxItem}">
                        <Setter Property="Foreground" Value="{StaticResource TextSubBrush}"/>
                        <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                    <Border x:Name="itemBorder"
                                            Background="Transparent"
                                            CornerRadius="9"
                                            Padding="0">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#1B2A3D"/>
                                            <Setter Property="Foreground" Value="#E9F4FF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                            <Setter Property="Foreground" Value="#78FFAE"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="itemBorder" Property="Opacity" Value="0.45"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBox}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="rootGrid" Background="{StaticResource WindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="155"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#10253A" Offset="0"/>
                    <GradientStop Color="#071018" Offset="0.65"/>
                    <GradientStop Color="#092016" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="24,22,24,0">
                <StackPanel VerticalAlignment="Top">
                    <Border Background="#163B29"
                            BorderBrush="#245B3E"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="10,4"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,12">
                        <TextBlock x:Name="txtTopBadge" Text="CN PRIVATE SERVER"
                                   Foreground="#7DFFAE"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   />
                    </Border>

                    <TextBlock x:Name="txtAppTitle" Text="5th Echelon"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#F7FBFF"
                               Margin="0,-1,0,1"/>

                    <Border x:Name="bdAnnouncementClip"
                            Width="330"
                            Height="22"
                            HorizontalAlignment="Left"
                            ClipToBounds="True"
                            MouseEnter="AnnouncementClip_MouseEnter"
                            MouseLeave="AnnouncementClip_MouseLeave"
                            SizeChanged="AnnouncementClip_SizeChanged">
                        <Canvas x:Name="announcementCanvas" Height="22">
                            <TextBlock x:Name="txtAppSubtitle"
                                       Text="OK兄弟们，干起来♂"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSubBrush}"
                                       TextWrapping="NoWrap"
                                       Canvas.Top="1">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="announcementTransform" X="0"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Canvas>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel x:Name="spTitleButtons"
                    Grid.Row="0"
                    Panel.ZIndex="20"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,10,12,0">
            <Button x:Name="btnLanguageToggle"
                    Content="中文 / EN"
                    Style="{StaticResource TitleBarTextButton}"
                    Click="LanguageToggleButton_Click"
                    Margin="0,0,4,0"/>
            <Button x:Name="btnMusicToggle"
                    Content="🔊"
                    Style="{StaticResource WindowChromeButton}"
                    Click="MusicToggleButton_Click"
                    Margin="0,0,4,0"/>
            <Button x:Name="btnGuide"
                    Content="?"
                    Style="{StaticResource WindowChromeButton}"
                    Click="GuideButton_Click"
                    Margin="0,0,4,0"/>
            <Button x:Name="btnWindowMinimize"
                    Content="—"
                    Style="{StaticResource WindowChromeButton}"
                    Click="WindowMinimizeButton_Click"/>
            <Button x:Name="btnWindowClose"
                    Content="×"
                    Style="{StaticResource WindowChromeCloseButton}"
                    Click="WindowCloseButton_Click"
                    Margin="4,0,0,0"/>
        </StackPanel>


        <Border Grid.RowSpan="2"
                Margin="18,126,18,18"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="22"
                Padding="20"
                Effect="{StaticResource CardShadow}">
            <StackPanel>
                <Grid Margin="0,0,0,14">
                    <TextBlock x:Name="txtSectionTitle"
                               FontSize="16"
                               FontWeight="Bold"
                               VerticalAlignment="Center"><Run Language="zh-cn" Text="基本信息"/></TextBlock>
                    <Button x:Name="btnPlayers"
                            HorizontalAlignment="Right"
                            MinWidth="154"
                            Height="31"
                            Content="当前在线玩家：1"
                            Style="{StaticResource SmallButton}"
                            Click="PlayersButton_Click"/>
                </Grid>



                <!-- 公网专版不再显示 RADMIN/服务器输入/主机发现相关控件。
                     公网入口、虚拟服务端地址均由后台固定配置。 -->

                <Grid Margin="0,0,0,13">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="txtUsernameLabel" Text="账号" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtUsername" Style="{StaticResource CenterTextBox}"
                                 InputMethod.IsInputMethodEnabled="False"
                                 InputMethod.PreferredImeState="Off"
                                 InputScope="AlphanumericHalfWidth"
                                 PreviewTextInput="UsernameTextBox_PreviewTextInput"
                                 DataObject.Pasting="UsernameTextBox_Pasting"
                                 TextChanged="UsernameTextBox_TextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="txtPasswordLabel" Text="密码" Style="{StaticResource FieldLabel}"/>
                        <PasswordBox x:Name="txtPassword" Style="{StaticResource CenterPasswordBox}"
                                     PreviewTextInput="PasswordBox_PreviewTextInput"
                                     DataObject.Pasting="PasswordBox_Pasting"/>
                    </StackPanel>
                </Grid>

                <Border x:Name="bdStatusPanel" Background="{StaticResource CardLightBrush}"
                        BorderBrush="#243850"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12"
                        Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="24"
                                Height="24"
                                Background="#0B141D"
                                BorderBrush="#334961"
                                BorderThickness="1"
                                CornerRadius="12"
                                Margin="0,0,10,0">
                            <Ellipse x:Name="serverStatusLight"
                                     Width="10"
                                     Height="10"
                                     Fill="Gray"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="txtConnectionStatusCaption" Text="连接状态"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="10"
                                       Margin="0,0,0,1"/>
                            <TextBlock x:Name="txtServerStatus"
                                       Text="未检测"
                                       Foreground="#D7E6F7"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                x:Name="btnCheckNetwork"
                                MinWidth="86"
                                Content="检测网络"
                                Style="{StaticResource SmallButton}"
                                Click="CheckNetworkButton_Click"
                                Margin="12,0,0,0"/>

                    </Grid>
                </Border>

                <TextBlock x:Name="txtLaunchModeLabel" Text="启动模式" Style="{StaticResource FieldLabel}"/>
                <ListBox x:Name="cmbGameExecutable"
                         Style="{StaticResource ModeListBox}"
                         SelectedIndex="0"
                         Margin="0,0,0,16">
                    <ListBoxItem Content="DX9"/>
                    <ListBoxItem Content="DX11"/>
                </ListBox>

                <Button x:Name="btnLaunch"
                        Content="启动游戏"
                        Style="{StaticResource PrimaryButton}"
                        Click="LaunchButton_Click"
                        Margin="0,2,0,14"/>
            </StackPanel>
        </Border>
        <TextBlock x:Name="txtFooterNotice"
                   Style="{StaticResource FieldLabel}" 
                   Margin="39,339,40,0" 
                   Grid.Row="1"
                   FontWeight="Bold"
                   VerticalAlignment="Top"
                   TextWrapping="WrapWithOverflow"
                   ><Run Text="友情提示： 本启动器基于开源项目 5th Echelon 优化制作，"/><Run Text="一键接入，方便游玩。"/><LineBreak/><Run/><Run Text="原项目地址：https://github.com/unixoide/5th-echelon "/><LineBreak/><Run/><LineBreak/><Run Text="国内联机交流群：709112052 "/><LineBreak/><Run Text="等你来♂战！"/></TextBlock>

        <TextBlock x:Name="txtLauncherVersion"
                   Grid.Row="1"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,38,22"
                   Foreground="#70869C"
                   FontSize="10"
                   FontWeight="SemiBold"
                   MouseLeftButtonUp="LauncherVersion_MouseLeftButtonUp"
                   Text="公网专版 v0.3.7"/>


        <Grid x:Name="playersOverlay"
              Grid.RowSpan="2"
              Panel.ZIndex="80"
              Visibility="Collapsed"
              Background="#66000000">
            <Border Width="{Binding ActualWidth, ElementName=btnLaunch}"
                    MaxHeight="520"
                    Background="#121F2D"
                    BorderBrush="#35506B"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#000000"
                                      BlurRadius="28"
                                      ShadowDepth="8"
                                      Opacity="0.45"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="txtPlayersTitle"
                               Grid.Row="0"
                               Text="当前在线玩家"
                               Foreground="{StaticResource TextMainBrush}"
                               FontSize="17"
                               FontWeight="Bold"
                               Margin="0,0,0,14"/>

                    <Grid Grid.Row="1" Margin="10,0,10,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="112"/>
                            <ColumnDefinition Width="72"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="txtPeerHeaderName"
                                   Grid.Column="0"
                                   Text="玩家ID"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="txtPeerHeaderIp"
                                   Grid.Column="1"
                                   Text="虚拟IP"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="txtPeerHeaderLatency"
                                   Grid.Column="2"
                                   Text="延迟"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   TextAlignment="Right"/>
                    </Grid>

                    <ScrollViewer Grid.Row="2"
                                  MaxHeight="330"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="spPeerList"/>
                    </ScrollViewer>

                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,16,0,0">
                        <Button x:Name="btnClosePlayers"
                                MinWidth="72"
                                Content="取消"
                                Style="{StaticResource DialogSecondaryButton}"
                                Click="ClosePlayersButton_Click"
                                Margin="0,0,10,0"/>
                        <Button x:Name="btnRefreshPlayers"
                                MinWidth="72"
                                Content="刷新"
                                Style="{StaticResource DialogPrimaryButton}"
                                Click="RefreshPlayersButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="dialogOverlay"
              Grid.RowSpan="2"
              Visibility="Collapsed"
              Background="#66000000">
            <Border Width="{Binding ActualWidth, ElementName=btnLaunch}"
                    MaxHeight="520"
                    Background="#121F2D"
                    BorderBrush="#35506B"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#000000"
                                      BlurRadius="28"
                                      ShadowDepth="8"
                                      Opacity="0.45"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="txtDialogTitle"
                               Grid.Row="0"
                               Text="提示"
                               Foreground="{StaticResource TextMainBrush}"
                               FontSize="17"
                               FontWeight="Bold"
                               Margin="0,0,0,14"/>

                    <ScrollViewer Grid.Row="1"
                                  MaxHeight="330"
                                  VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="txtDialogMessage"
                                   Text="消息内容"
                                   Foreground="{StaticResource TextSubBrush}"
                                   FontSize="13"
                                   LineHeight="22"
                                   TextWrapping="Wrap"
                                   Margin="0,0,8,0"/>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,16,0,0">
                        <Button x:Name="btnDialogNo"
                                MinWidth="72"
                                Content="取消"
                                Style="{StaticResource DialogSecondaryButton}"
                                Click="DialogNoButton_Click"
                                Margin="0,0,10,0"/>
                        <Button x:Name="btnDialogYes"
                                MinWidth="72"
                                Content="确定"
                                Style="{StaticResource DialogPrimaryButton}"
                                Click="DialogYesButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Canvas x:Name="guideOverlay"
                Grid.RowSpan="2"
                Panel.ZIndex="90"
                Visibility="Collapsed"
                Background="#66000000">
            <Border x:Name="guideHighlight"
                    BorderBrush="#7DFFAE"
                    BorderThickness="2"
                    CornerRadius="14"
                    Background="#18FFFFFF"
                    IsHitTestVisible="False"/>

            <TextBlock x:Name="guideArrow"
                       Text="▲"
                       Foreground="#7DFFAE"
                       FontSize="18"
                       FontWeight="Bold"
                       Panel.ZIndex="91"
                       IsHitTestVisible="False"/>

            <Border x:Name="guideCard"
                    Width="330"
                    Background="#121F2D"
                    BorderBrush="#3E6284"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="14">
                <Border.Effect>
                    <DropShadowEffect Color="#000000"
                                      BlurRadius="30"
                                      ShadowDepth="8"
                                      Opacity="0.5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="txtGuideStep"
                               Text="1 / 6"
                               Foreground="#7DFFAE"
                               FontSize="11"
                               FontWeight="Bold"
                               Margin="0,0,0,6"/>
                    <TextBlock x:Name="txtGuideTitle"
                               Text="指引标题"
                               Foreground="{StaticResource TextMainBrush}"
                               FontSize="17"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>
                    <TextBlock x:Name="txtGuideMessage"
                               Text="指引内容"
                               Foreground="{StaticResource TextSubBrush}"
                               FontSize="12.3"
                               LineHeight="19"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnGuideSkip"
                                Content="跳过"
                                Width="62"
                                Style="{StaticResource DialogSecondaryButton}"
                                Click="GuideSkipButton_Click"
                                Margin="0,0,8,0"/>
                        <Button x:Name="btnGuidePrev"
                                Content="上一步"
                                Width="72"
                                Style="{StaticResource DialogSecondaryButton}"
                                Click="GuidePrevButton_Click"
                                Margin="0,0,8,0"/>
                        <Button x:Name="btnGuideNext"
                                Content="下一步"
                                Width="76"
                                Style="{StaticResource DialogPrimaryButton}"
                                Click="GuideNextButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Canvas>

    </Grid>
</Window>